# Postgres (Railway EU / lokal). Beispiel Railway:
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Compute-Service (FastAPI, schwerer Geometrie-Compute). Default lokal:
HOEHENVERGLEICH_COMPUTE_URL=http://localhost:8000

# Portal-SSO (Stub): Secret zum Verifizieren des Portal-JWT.
# TODO Portal-Integration: echtes Secret/JWKS aus dem Gateway übernehmen.
PORTAL_JWT_SECRET=dev-only-not-secret

# Portal-Basis-URL für die einheitliche App-Liste der Sidebar
# (serverseitiger Fetch von /api/portal/modules-meta). Auf Railway als ENV
# setzen, intern: http://portal.railway.internal:8080
# Leer/ungesetzt => Sidebar nutzt die lokale Registry (Fallback).
PORTAL_URL=http://portal.railway.internal:8080
